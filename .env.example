# Supabase (client-side, safe to expose — protected by RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-only — NEVER prefix with VITE_. Set these as Edge Function secrets, not here.
# (Edge Functions auto-receive SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.)
# Owner notifications (optional; submit-lead/submit-booking no-op until set):
#   supabase secrets set TELEGRAM_BOT_TOKEN=xxx TELEGRAM_CHAT_ID=xxx
